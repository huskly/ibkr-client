{
  "name": "@huskly/ibkr-client",
  "version": "0.4.0",
  "description": "Interactive Brokers Web API client (OAuth 1.0a) and terminal CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ibkr-cli": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": "github.com/huskly/ibkr-client",
  "author": "Felipe Lima",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit -p tsconfig.test.json && node --import tsx --test test/**/*.test.ts",
    "clean": "rm -rf dist",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "dotenv": "^17.2.3",
    "ibkr-client": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^26.1.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10",
    "prettier": "^3.9.6",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.49.0"
  }
}
