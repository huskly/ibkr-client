# IBKR OAuth 1.0a credentials.
# Copy to `.env` and fill in the values from the IBKR self-service portal.
# The .pem key files and the DH prime are picked up automatically from this
# directory by main.py, so they do NOT need to be set here.

# 9-character consumer key issued by IBKR
IBIND_OAUTH1A_CONSUMER_KEY=

# Access token + secret generated in the IBKR portal
IBIND_OAUTH1A_ACCESS_TOKEN=
IBIND_OAUTH1A_ACCESS_TOKEN_SECRET=

# Optional: override the account id to query (otherwise the first account is used)
# IBKR_ACCOUNT_ID=
